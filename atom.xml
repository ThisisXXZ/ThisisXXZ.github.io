  <entry>
    <title>The Missing Semester of CS Education, MIT - Data Wrangling</title>
    <link href="https://www.thisisxxz.com/2023/07/06/missing-sem-2/"/>
    <id>https://www.thisisxxz.com/2023/07/06/missing-sem-2/</id>
