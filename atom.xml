  <entry>
    <title>Programming Languages, UW, Part B - Static Checking</title>
    <link href="https://www.thisisxxz.com/2023/07/19/prog-lan-3/"/>
    <id>https://www.thisisxxz.com/2023/07/19/prog-lan-3/</id>
